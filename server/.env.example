# 服务端口（默认 3000）
PORT=3000

# 数据库文件路径（SQLite）
DATABASE_URL="file:./dev.db"

# JWT 签名密钥（必填，请使用随机字符串）
JWT_SECRET="your-secret-key-here"

# 允许的跨域来源（多个用逗号分隔，不设则默认 http://localhost:5173）
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# 大模型 API 兼容端点（支持任意 OpenAI 兼容 API）
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY="your-api-key-here"

# 模型名称（如 deepseek-chat、deepseek-reasoner 等）
DEEPSEEK_MODEL="deepseek-chat"

# AI 人设（可选，指定 prompts/ 目录下的文件名）
# 也支持直接用 SYSTEM_PROMPT 环境变量写简短的提示词
PERSONA=character,system
