{
  "name": "ai-chat-server",
  "version": "1.0.0",
  "description": "AI Chat 后端服务 — Express + Prisma + OpenAI 兼容 API",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.17.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.97.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^24.12.2",
    "prisma": "^6.17.0",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3"
  }
}
