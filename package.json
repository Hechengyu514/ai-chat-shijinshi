{
  "name": "ai-chat",
  "version": "1.0.0",
  "description": "AI 对话应用 — Vue 3 + Element Plus 前端，Express + Prisma 后端，支持流式 SSE 与大模型对话",
  "private": true,
  "type": "module",
  "keywords": [
    "ai",
    "chat",
    "vue3",
    "express",
    "prisma",
    "sse",
    "openai"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "pnpm run build-only && wrangler dev",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "pnpm run build-only && wrangler deploy"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.15.2",
    "dompurify": "^3.4.1",
    "element-plus": "^2.13.7",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "happy-dom": "^20.9.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.60.0",
    "prettier": "3.8.3",
    "typescript": "~6.0.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.88.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
